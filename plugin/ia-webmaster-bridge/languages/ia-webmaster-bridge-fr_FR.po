msgid "IP allow-list saved with %d invalid entry dropped."
msgid_plural "IP allow-list saved with %d invalid entries dropped."
msgstr[0] "Liste d’IP autorisées enregistrée avec %d entrée invalide supprimée."
msgstr[1] "Liste d’IP autorisées enregistrée avec %d entrées invalides supprimées."
