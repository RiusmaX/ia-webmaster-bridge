msgid "The 'login' and 'email' parameters are required."
msgstr "Les paramètres « login » et « email » sont requis."

msgid "The 'name' parameter is required."
msgstr "Le paramètre « name » est requis."

msgid "The 'settings' parameter (object) is required."
msgstr "Le paramètre « settings » (objet) est requis."

msgid "The 'terms' parameter (array) is required."
msgstr "Le paramètre « terms » (tableau) est requis."

msgid "The 'url' parameter is required."
msgstr "Le paramètre « url » est requis."

msgid "The adapter is not configured: no API credentials."
msgstr "L’adaptateur n’est pas configuré : aucune identifiant d’API."

msgid "The adapter performs every write under this single WordPress user, regardless of which API key signed the request. The user has a restricted role with the highest-risk capabilities stripped out."
msgstr "L’adaptateur effectue chaque écriture sous cet unique utilisateur WordPress, quelle que soit la clé d’API qui a signé la requête. L’utilisateur a un rôle restreint, privé des capacités les plus risquées."

msgid "The dedicated agent user cannot be modified via the API."
msgstr "L’utilisateur dédié de l’agent ne peut pas être modifié via l’API."

msgid "The dedicated agent user could not be located. Click below to (re)install."
msgstr "L’utilisateur dédié de l’agent est introuvable. Cliquez ci-dessous pour (ré)installer."

msgid "The IA Webmaster Bridge plugin cannot be deactivated via the API."
msgstr "L’extension IA Webmaster Bridge ne peut pas être désactivée via l’API."

msgid "The IA Webmaster Bridge plugin cannot be updated via its own API. Use the WordPress admin instead."
msgstr "L’extension IA Webmaster Bridge ne peut pas être mise à jour via sa propre API. Utilisez plutôt l’administration WordPress."

msgid "The layout contains blocks outside the divi/ namespace."
msgstr "Le layout contient des blocs en dehors de l’espace de noms divi/."

msgid "The URL does not point to a file with a named extension."
msgstr "L’URL ne pointe pas vers un fichier avec une extension nommée."

msgid "The Yoast backend is not yet implemented (backlog)."
msgstr "Le backend Yoast n’est pas encore implémenté (en backlog)."

#. translators: %s: theme stylesheet slug.
msgid "Theme '%s' is not installed."
msgstr "Le thème « %s » n’est pas installé."

msgid "Theme is not allowed on this site."
msgstr "Le thème n’est pas autorisé sur ce site."

msgid "Theme not found after install."
msgstr "Thème introuvable après l’installation."

msgid "This site requires HTTPS for the API. Re-issue your request over https://."
msgstr "Ce site exige HTTPS pour l’API. Renvoyez votre requête en https://."

#. translators: HTTP 403 error code (iawm_protected_user) shown verbatim.
msgid "This user cannot be modified or deleted through the API (HTTP 403 <code>iawm_protected_user</code>)."
msgstr "Cet utilisateur ne peut être ni modifié ni supprimé via l’API (HTTP 403 <code>iawm_protected_user</code>)."

msgid "Time"
msgstr "Date"

msgid "Tools"
msgstr "Outils"

msgid "true (enforced)"
msgstr "true (forcé)"

msgid "Two daily cron jobs trim the audit log and the backup table to the limits below. Defaults: 90 days of audit, 50 backups."
msgstr "Deux tâches cron quotidiennes nettoient le journal d’audit et la table des sauvegardes selon les limites ci-dessous. Par défaut : 90 jours d’audit, 50 sauvegardes."

#. translators: 1: unknown bucket name. 2: comma-separated list of valid buckets.
msgid "Unknown bucket: %1$s. Use one of: %2$s"
msgstr "Bucket inconnu : %1$s. Utilisez l’un de : %2$s"

msgid "Unknown key identifier."
msgstr "Identifiant de clé inconnu."

#. translators: %s: theme menu-location slug.
msgid "Unknown menu location: %s."
msgstr "Emplacement de menu inconnu : %s."

#. translators: %s: unsupported "mode" value.
msgid "Unknown mode: %s."
msgstr "Mode inconnu : %s."

#. translators: %s: schedule slug that was rejected.
msgid "Unknown schedule slug '%s'. Use /cron/schedules to list valid ones."
msgstr "Slug de planification inconnu « %s ». Utilisez /cron/schedules pour lister les slugs valides."

#. translators: %s: taxonomy slug.
msgid "Unknown taxonomy: %s."
msgstr "Taxonomie inconnue : %s."

msgid "Unnamed"
msgstr "Sans nom"

#. translators: %s: requested content type.
msgid "Unsupported content type: %s."
msgstr "Type de contenu non pris en charge : %s."

#. translators: %s: WordPress role slug that was rejected.
msgid "Unsupported role: %s."
msgstr "Rôle non pris en charge : %s."

msgid "Unsupported status for writing."
msgstr "Statut non pris en charge pour l’écriture."

msgid "Untitled key"
msgstr "Clé sans titre"

msgid "Update failed."
msgstr "La mise à jour a échoué."

msgid "User ID"
msgstr "ID utilisateur"

#. translators: %d: WordPress user ID that was not found.
msgid "User not found: %d."
msgstr "Utilisateur introuvable : %d."

#. translators: HTML <code> tags wrap PHP constant + file names; left verbatim.
msgid "When the <code>IAWM_REQUIRE_HTTPS</code> constant is set to <code>true</code> in <code>wp-config.php</code>, non-HTTPS API calls are refused before any signature work. Configuration via a constant (not an admin toggle) prevents a compromised admin from disabling the protection."
msgstr "Lorsque la constante <code>IAWM_REQUIRE_HTTPS</code> est mise à <code>true</code> dans <code>wp-config.php</code>, les appels d’API non HTTPS sont refusés avant tout travail de signature. La configuration par une constante (et non par un bouton d’admin) empêche un admin compromis de désactiver la protection."

#. translators: 1: WordPress target version. 2: required PHP version. 3: current PHP version on the server.
msgid "WordPress %1$s requires PHP %2$s or higher; this server runs PHP %3$s. Update PHP first."
msgstr "WordPress %1$s requiert PHP %2$s ou supérieur ; ce serveur exécute PHP %3$s. Mettez d’abord PHP à jour."

msgid "WordPress did not return an upgrade offer; cannot apply the update."
msgstr "WordPress n’a pas retourné d’offre de mise à niveau ; impossible d’appliquer la mise à jour."

msgid "Writes are disabled (kill switch on)."
msgstr "Les écritures sont désactivées (interrupteur d’arrêt activé)."

msgid "yes"
msgstr "oui"

msgid "zone must be header, body or footer."
msgstr "zone doit être header, body ou footer."

#. translators: %d: number of days elapsed since the key was last used.
msgid "%d d ago"
msgid_plural "%d d ago"
msgstr[0] "il y a %d j"
msgstr[1] "il y a %d j"

#. translators: %d: number of audit log entries.
msgid "%d entry"
msgid_plural "%d entries"
msgstr[0] "%d entrée"
msgstr[1] "%d entrées"

#. translators: %d: number of hours elapsed since the key was last used.
msgid "%d h ago"
msgid_plural "%d h ago"
msgstr[0] "il y a %d h"
msgstr[1] "il y a %d h"

#. translators: %d: number of minutes elapsed since the key was last used.
msgid "%d min ago"
msgid_plural "%d min ago"
msgstr[0] "il y a %d min"
msgstr[1] "il y a %d min"

#. translators: %d: number of audit-log rows deleted.
msgid "Audit log pruned: %d row deleted."
msgid_plural "Audit log pruned: %d rows deleted."
msgstr[0] "Journal d’audit purgé : %d ligne supprimée."
msgstr[1] "Journal d’audit purgé : %d lignes supprimées."

#. translators: %d: number of backup records deleted.
msgid "Backups pruned: %d record deleted."
msgid_plural "Backups pruned: %d records deleted."
msgstr[0] "Sauvegardes purgées : %d enregistrement supprimé."
msgstr[1] "Sauvegardes purgées : %d enregistrements supprimés."

