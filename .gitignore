# Node dependencies
node_modules/

# Sensitive configuration — NEVER publish (HMAC secret, site URL)
config.json

# MCP gateway build: only the self-contained bundle is versioned
claude-plugin/mcp-gateway/dist/*
!claude-plugin/mcp-gateway/dist/index.js

# Temporary local MCP connection (absolute path, dev-machine specific)
/.mcp.json

# Project-specific / client scripts — NEVER in the public repo.
# The repo must stay agnostic: it ships the plugin + the connector,
# not integrations specific to a given site. Per-client scripts live
# in a folder outside the repo (e.g. ../iawm-clients/<name>/).
tools/*-client.mjs
tools/*-client.php
tools/clients/

# Personal preferences of the current maintainer (language, style, dev env).
# The versioned CLAUDE.md stays generic for the public; CLAUDE.local.md
# holds preferences specific to the workstation.
CLAUDE.local.md

# Misc
*.log
.DS_Store
Thumbs.db
